rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /media-items/{itemId} {
      allow read, write: if true;

      match /chunks/{chunkId} {
        allow read, write: if true;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
